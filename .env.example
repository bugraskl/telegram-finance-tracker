# ============================================================
#  Finance Dashboard — environment / ortam değişkenleri
#  Copy to ".env" and fill in. / ".env" olarak kopyalayıp doldurun.
# ============================================================

# --- Login / Giriş (REQUIRED / ZORUNLU) ---
APP_USERNAME=admin
APP_PASSWORD=change-me-to-a-strong-password

# Session signing key. Generate with / şununla üretin:
#   openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-string

# --- Data file location / Veri dosyası konumu ---
# Host folder the n8n bot writes expenses.jsonl into.
# n8n botunun expenses.jsonl yazdığı HOST klasörü.
# Find it with / şununla bulun:
#   docker inspect <n8n-container> --format '{{range .Mounts}}{{.Source}} -> {{.Destination}}{{"\n"}}{{end}}'
# Use the Source that maps to the container's downloads folder.
N8N_DOWNLOADS_DIR=/home/youruser/n8n_downloads

# --- Optional / İsteğe bağlı ---
APP_PORT=8095
TOKEN_TTL_DAYS=30

# uid:gid the container runs as — must match the owner of expenses.jsonl
# (n8n default is 1000). expenses.jsonl sahibiyle aynı olmalı (n8n varsayılanı 1000).
APP_UID=1000
APP_GID=1000

# TL conversion rates (defaults shown). TL'ye çevrim kurları (varsayılan).
# CURRENCY_RATES={"EUR":47,"USD":41,"GBP":53}
